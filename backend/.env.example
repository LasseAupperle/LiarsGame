# Backend Environment Variables

# Server port
PORT=3000
NODE_ENV=development

# CORS: Allowed origins (comma-separated or wildcard for dev)
CORS_ORIGIN=http://localhost:5173,https://your-netlify-domain.netlify.app

# Redis (optional - for lobby/session persistence)
# Leave empty to use in-memory store
REDIS_URL=

# Logging level
LOG_LEVEL=debug

# Production settings
# NODE_ENV=production
# PORT=3000
# CORS_ORIGIN=https://your-domain.netlify.app

