# Backend Environment Variables
# Server port (use 8000 for local development)
PORT=8000
NODE_ENV=development

# CORS: Allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,https://your-netlify-domain.netlify.app

# Redis (optional - for lobby/session persistence)
# Leave empty to use in-memory store
REDIS_URL=

# Logging level
LOG_LEVEL=debug
